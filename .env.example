# LinkedIn credentials
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=your-password

# Newsletter name — must match exactly in LinkedIn UI
NEWSLETTER_NAME=OLDaily

# URL of the OLDaily HTML page to fetch
SOURCE_URL=https://www.downes.ca/news/OLDaily.htm

# LinkedIn article composer URL (contains your author URN)
COMPOSER_URL=https://www.linkedin.com/article/new/?author=urn%3Ali%3Afsd_profile%3AACoAAAAI52YBB6qnG3mdwHncS6-Lx5nnkx5Rz8I

# Token gRSShopper sends with the POST request to /publish
PUBLISH_TOKEN=change-this-to-a-random-secret

# Paths inside the container (normally leave as-is)
PROFILE_DIR=/app/chrome_profile
POSTED_PATH=/app/data/posted.json
TIMEZONE=America/Toronto

# Set true for server (headless); set false only for interactive login troubleshooting
HEADLESS=true

# VNC password for one-time manual login session (remove port 5900 from docker-compose.yml when done)
VNC_PASSWORD=change-this

# Show publisher output in docker logs immediately (recommended)
PYTHONUNBUFFERED=1
